# Copy this file to .env and fill in your values

# MongoDB Atlas connection string
# Get this from: https://cloud.mongodb.com -> Connect -> Drivers
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/rider?retryWrites=true&w=majority

# JWT secret - use a long random string in production
JWT_SECRET=replace_with_a_very_long_random_secret_string

# Your deployed Vercel frontend URL (no trailing slash)
FRONTEND_URL=https://rider-git-main-darshanshinde7455-5116s-projects.vercel.app

# Port (Render sets this automatically)
PORT=5000